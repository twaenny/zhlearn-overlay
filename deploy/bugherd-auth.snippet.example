# Bugherd API authentication snippet for the nginx /api/bugherd/ proxy.
#
# Setup:
#   1. Grab your Bugherd API key at https://www.bugherd.com/settings/api
#   2. Compute: printf "YOUR_API_KEY:x" | base64
#   3. Copy this file: cp bugherd-auth.snippet.example bugherd-auth.snippet
#   4. Replace BASE64_VALUE below with the base64 output from step 2
#   5. Reload nginx: docker exec ai-zhlearn nginx -t && \
#                     docker exec ai-zhlearn nginx -s reload
#
# The real snippet file (without .example) is gitignored — your API
# key never lands in the repo. The container picks it up via the
# existing deploy/ bind-mount.

proxy_set_header Authorization "Basic BASE64_VALUE";
